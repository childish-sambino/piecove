# piecove config — lives at ~/.piecove/config.env (created by `piecove init`).
# Holds your provider choice and keys; keep it chmod 600.

# ── Provider + model (one set of vars drives BOTH Claude Code and Pi) ─────────
# PROVIDER: fireworks | zai | openrouter | anthropic | bedrock | local
PROVIDER=fireworks

# MODEL: leave blank to use the provider's default
#   fireworks  → accounts/fireworks/models/glm-5p2
#   zai        → glm-5.2
#   openrouter → z-ai/glm-5.2   (any OpenRouter slug, e.g. anthropic/claude-opus-4.8)
#   anthropic  → claude-opus-4-8
#   local      → qwen2.5-coder:7b   (Ollama on your host; Pi only)
MODEL=

# Your API key for that provider. For `anthropic` this is your Anthropic key.
# For `bedrock`, leave blank and set AWS_* below instead. For `local`, leave blank.
#
# To use your Anthropic SUBSCRIPTION (Claude Pro/Max) instead of a key: set
# PROVIDER=anthropic, leave PIECOVE_API_KEY blank, then run `claude` and `/login`
# in the container — the OAuth login persists in the home volume. (Claude Code is
# first-party so it draws on your plan; Pi can /login too but Anthropic bills
# third-party harnesses per-token as extra usage, not against plan limits.)
PIECOVE_API_KEY=

# ── Cost lab (optional; metering, budget, routing — see `piecove cost`) ───────
# Dollar budget for the session; warns at 80%, then stops on breach (interactive Pi
# asks to stop-and-resume-later or raise the cap; headless hard-stops).
# PIECOVE_BUDGET=5
#
# Active tier routing: set these to model ids YOUR provider serves and each turn's
# model is rewritten to the classified tier (trivial→local, hard→frontier). Needs a
# multi-model endpoint like openrouter. Leave unset to keep routing advisory-only.
# PIECOVE_ROUTE_LOCAL=z-ai/glm-5.2
# PIECOVE_ROUTE_STANDARD=z-ai/glm-5.2
# PIECOVE_ROUTE_FRONTIER=anthropic/claude-opus-4.8

# ── GitHub (optional: commit/push + clone private repos) ─────────────────────
# Fine-grained, expiring token scoped to just the repos you need — the agent can
# read its own env, so keep the blast radius small. git identity is auto-detected
# from your host git config (no need to set name/email here).
GH_TOKEN=

# ── Image extras (optional; rebuilds the image when changed) ─────────────────
# Space-separated apt/npm packages baked into your image — a system lib some
# native gem needs, or a service CLI you want in every session.
# PIECOVE_EXTRA_APT=libvips-dev
# PIECOVE_EXTRA_NPM=heroku

# ── Ruby version (optional) ──────────────────────────────────────────────────
# Auto-detected from the working dir's .ruby-version / Gemfile. Set to force one.
# RUBY_VERSION=3.4.1

# ── Postgres (auto-started when the repo uses it; --db / --no-db to force) ────
# Defaults (localhost / postgres / postgres) are baked in. Override only if needed.
# PGUSER=postgres
# PGPASSWORD=postgres
# PGPORT=5432

# ── Redis (auto-started when a served Rails app needs it) ────────────────────
# REDIS_PORT=6379

# ── Bedrock only (PROVIDER=bedrock) ──────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-west-2
